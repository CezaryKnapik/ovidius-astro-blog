---
import { type CollectionEntry } from 'astro:content';
import { defaultLocale, type Locale } from '../i18n/config';
import { ui } from '../i18n/ui';
import { postUrl } from '../utils/i18n';
import CustomImage from './CustomImage.astro';
import FormattedDate from './FormattedDate.astro';

const { post, locale = defaultLocale } = Astro.props as { post: CollectionEntry<'blog'>; locale?: Locale };
const { title, publishDate, updatedDate, featureImage } = post.data;
const postHref = postUrl(locale, post);
const labels = ui[locale].common;
---

<article class="flex flex-col mb-12 gap-x-8 gap-y-6 sm:flex-row">
    <header class="grow">
        <div class="mb-2 text-sm tracking-wider uppercase text-slate-500">
            <FormattedDate date={publishDate} locale={locale} />
            {
                updatedDate && (
                    <>
                        {' '}
                        <span>
                            ({labels.updatedOn} <FormattedDate date={updatedDate} locale={locale} />)
                        </span>
                    </>
                )
            }
        </div>
        <h3 class="text-2xl font-bold text-slate-900">
            <a href={postHref}>{title}</a>
        </h3>
    </header>
    {
        featureImage?.src && (
            <figure class="shrink-0 sm:w-40">
                <a href={postHref}>
                    <CustomImage
                        {...featureImage}
                        class="w-full rounded-md"
                        widths={[160, 320, 480, 640]}
                        sizes="(min-width: 640px) 160px, calc(100vw - 32px)"
                    />
                </a>
            </figure>
        )
    }
</article>
