---
import HeaderNavLink from './HeaderNavLink.astro';
import { defaultLocale, type Locale } from '../i18n/config';
import { ui } from '../i18n/ui';
import type { AlternateLink, SiteConfig } from '../types';
import LanguageSwitcher from './LanguageSwitcher.astro';

type Props = {
    class?: string;
    locale?: Locale;
    siteConfig: SiteConfig;
    alternateLinks?: AlternateLink[];
};

const { class: className, locale = defaultLocale, siteConfig, alternateLinks = [] } = Astro.props as Props;
const navLinks = siteConfig.navLinks ?? [];
const labels = ui[locale].navigation;
---

<header class:list={['flex items-center justify-end gap-6 px-4 py-4 sm:px-8 sm:py-6', className]}>
    <div class="flex items-center gap-3">
        <LanguageSwitcher locale={locale} alternateLinks={alternateLinks} />
        {
            navLinks.length > 0 && (
            <nav class="relative" aria-label={labels.primary}>
                <button
                    class="relative z-20 inline-flex items-center justify-center w-10 h-10 text-white transition-shadow duration-300 rounded-full cursor-pointer menu-toggle bg-primary hover:shadow-button"
                    aria-label={labels.openMenu}
                    aria-expanded="false"
                    aria-controls="menu-items"
                    data-open-label={labels.openMenu}
                    data-close-label={labels.closeMenu}
                >
                    <span class="relative w-1 h-1 bg-white rounded-full menu-toggle-icon" />
                </button>
                <ul id="menu-items" class="absolute z-10 px-8 pt-16 pb-10 border menu -top-3 -right-3 border-white/40 bg-white/75 sm:px-12 sm:pt-20 sm:pb-16">
                    {navLinks.map((link) => (
                        <li class="mb-1 border-b border-slate-200/70">
                            <HeaderNavLink
                                class="relative block py-1 pr-6 text-lg font-bold transition duration-300 text-slate-700 hover:text-slate-500 sm:text-xl"
                                href={link.href}
                            >
                                {link.text}
                            </HeaderNavLink>
                        </li>
                    ))}
                </ul>
            </nav>
            )
        }
    </div>
</header>

<style>
    @reference "tailwindcss";

    .menu {
        width: calc(100vw - 0.5rem);
        max-width: 18.75rem;
        border-radius: 26px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(5px);
        opacity: 0;
        transform: scale(0.6);
        transform-origin: top right;
        transition:
            transform 0.2s cubic-bezier(0.4, 0, 0.2, 1) 0.3s,
            opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1) 0.25s,
            visibility 0s 0.5s;
        visibility: hidden;
    }
    .menu.is-visible {
        opacity: 1;
        transform: scale(1);
        transition:
            transform 0.25s cubic-bezier(0.4, 0, 0.2, 1) 0.25s,
            opacity 0.15s 0.15s,
            visibility 0s 0.25s;
        visibility: visible;
    }
    .menu-toggle-icon {
        transition:
            height 0s 0.25s,
            width 0s 0.25s;
    }
    .menu-toggle-icon.is-active {
        height: 3px;
        width: 3px;
    }
    .menu-toggle-icon:before,
    .menu-toggle-icon:after {
        @apply absolute top-1/2 left-1/2 h-1 w-1 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white;
        content: '';
        transition:
            width 0.25s cubic-bezier(0.4, 0, 0.2, 1),
            height 0s 0.25s,
            translate 0s 0.25s,
            rotate 0s 0.25s,
            margin 0.25s cubic-bezier(0.4, 0, 0.2, 1) 0.25s;
    }
    .menu-toggle-icon:before {
        @apply -ml-2;
    }
    .menu-toggle-icon:after {
        @apply ml-2;
    }
    .menu-toggle-icon.is-active:before,
    .menu-toggle-icon.is-active:after {
        @apply ml-0 w-5 rounded-md;
        height: 3px;
        transition:
            margin 0.25s cubic-bezier(0.4, 0, 0.2, 1),
            height 0s 0.25s,
            translate 0s 0.25s,
            rotate 0s 0.25s,
            width 0.25s cubic-bezier(0.4, 0, 0.2, 1) 0.25s;
    }
    .menu-toggle-icon.is-active:before {
        @apply rotate-45;
    }
    .menu-toggle-icon.is-active:after {
        @apply -rotate-45;
    }
</style>

<script>
    function menuToggle() {
        const menu = document.querySelector('.menu');
        const menuToggleBtn = document.querySelector('.menu-toggle');
        const menuToggleIcon = document.querySelector('.menu-toggle-icon');
        menuToggleBtn?.addEventListener('click', () => {
            const isMenuExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
            const openLabel = menuToggleBtn.getAttribute('data-open-label') ?? 'Open Menu';
            const closeLabel = menuToggleBtn.getAttribute('data-close-label') ?? 'Close Menu';
            menuToggleBtn.setAttribute('aria-expanded', isMenuExpanded ? 'false' : 'true');
            menuToggleBtn.setAttribute('aria-label', isMenuExpanded ? openLabel : closeLabel);
            menuToggleIcon?.classList.toggle('is-active');
            menu?.classList.toggle('is-visible');
        });
    }
    menuToggle();
    document.addEventListener('astro:after-swap', menuToggle);
</script>
