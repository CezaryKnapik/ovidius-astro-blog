---
import { defaultLocale, localeMetadata, type Locale } from '../i18n/config';

type Props = {
    date: Date;
    locale?: Locale;
};

const { date, locale = defaultLocale } = Astro.props;
---

<time datetime={date.toISOString()}>
    {
        date.toLocaleDateString(localeMetadata[locale].dateLocale, {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
        })
    }
</time>
