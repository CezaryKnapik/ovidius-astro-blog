---
import { getImage } from 'astro:assets';
import { getSiteConfig } from '../data/site-config';
import { defaultLocale, type Locale } from '../i18n/config';
import { ui } from '../i18n/ui';
import type { AlternateLink, ImageInput } from '../types';
import { localizedPath } from '../utils/i18n';

import '../styles/global.css';

export type Props = {
    title?: string;
    description?: string;
    image?: ImageInput | undefined;
    pageType?: 'website' | 'article';
    locale?: Locale;
    alternateLinks?: AlternateLink[];
};

const { locale = defaultLocale, description = '', pageType = 'website', alternateLinks = [] } = Astro.props;
const siteConfig = getSiteConfig(locale);
const title = [Astro.props.title, siteConfig.title].filter(Boolean).join(' | ');
const image = Astro.props.image ?? siteConfig.image;
const rssHref = localizedPath(locale, '/rss.xml');
let resolvedImage: { src: string; alt?: string } | undefined;
if (image?.src) {
    if (typeof image.src === 'string') {
        resolvedImage = {
            src: new URL(image.src, Astro.site).toString(),
            alt: image.alt
        };
    } else {
        const optimizedImage = await getImage({
            src: image.src as ImageMetadata,
            width: 1200,
            height: 630,
            format: 'jpeg',
            fit: 'cover'
        });
        resolvedImage = {
            src: new URL(optimizedImage.src, Astro.site).toString(),
            alt: image.alt
        };
    }
}
const canonicalURL = new URL(Astro.request.url, Astro.site);

/**
 * Enforce some standard canonical URL formatting across the site.
 */
function formatCanonicalURL(url: string | URL) {
    const path = url.toString();
    const hasQueryParams = path.includes('?');
    return path.replace(/\/?$/, hasQueryParams ? '' : '/');
}
---

<!-- High Priority Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="generator" content={Astro.generator} />

<!-- Fonts (self-hosted, full charset incl. Polish diacritics) -->
<link rel="preload" as="font" type="font/woff2" href="/fonts/figtree-wght-normal.woff2" crossorigin="anonymous" />
<link rel="stylesheet" href="/fonts/figtree.css?v=2" />

<!-- Low Priority Global Metadata -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" href={rssHref} title={ui[locale].common.rssTitle} />

<!-- Page Metadata -->
<link rel="canonical" href={formatCanonicalURL(canonicalURL)} />
{
    alternateLinks.map((link) => (
        <link rel="alternate" hreflang={link.hreflang} href={formatCanonicalURL(new URL(link.href, Astro.site))} />
    ))
}
{
    alternateLinks.find((link) => link.locale === defaultLocale) && (
        <link
            rel="alternate"
            hreflang="x-default"
            href={formatCanonicalURL(new URL(alternateLinks.find((link) => link.locale === defaultLocale)?.href ?? '/', Astro.site))}
        />
    )
}
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={pageType} />
<meta property="og:url" content={formatCanonicalURL(canonicalURL)} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
{resolvedImage?.src && <meta property="og:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta property="og:image:alt" content={resolvedImage.alt} />}

<!-- X/Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={formatCanonicalURL(canonicalURL)} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{resolvedImage?.src && <meta name="twitter:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta name="twitter:image:alt" content={resolvedImage.alt} />}
