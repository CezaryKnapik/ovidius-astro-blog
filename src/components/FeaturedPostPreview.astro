---
import { type CollectionEntry } from 'astro:content';
import { defaultLocale, type Locale } from '../i18n/config';
import { ui } from '../i18n/ui';
import { postUrl } from '../utils/i18n';
import CustomImage from './CustomImage.astro';
import FormattedDate from './FormattedDate.astro';
import PostTags from './PostTags.astro';

const { post, locale = defaultLocale } = Astro.props as { post: CollectionEntry<'blog'>; locale?: Locale };
const { title, publishDate, updatedDate, featureImage, excerpt, tags } = post.data;
const postHref = postUrl(locale, post);
const labels = ui[locale].common;
---

<article class="mb-12 sm:mb-16">
    <header class="max-w-3xl mx-auto">
        <div class="mb-2 text-sm tracking-wider uppercase text-slate-500 sm:mb-3">
            <span class="text-primary">{labels.featured}</span>
            {' / '}
            <FormattedDate date={publishDate} locale={locale} />
            {
                updatedDate && (
                    <>
                        {' '}
                        <span>
                            ({labels.updatedOn} <FormattedDate date={updatedDate} locale={locale} />)
                        </span>
                    </>
                )
            }
        </div>
        <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl md:text-5xl"><a href={postHref}>{title}</a></h2>
        <PostTags tags={tags} class="mt-4" />
    </header>
    {
        featureImage?.src && (
            <figure class="max-w-6xl mx-auto my-6 sm:my-8">
                <a href={postHref}>
                    <CustomImage
                        {...featureImage}
                        class="w-full rounded-md"
                        widths={[480, 640, 768, 960, 1200, 1600]}
                        sizes="(min-width: 1216px) 1152px, calc(100vw - 32px)"
                        fetchpriority="high"
                        loading="eager"
                    />
                </a>
            </figure>
        )
    }
    {
        excerpt && (
            <div class="max-w-3xl mx-auto mt-6">
                <div class="prose prose-slate sm:prose-lg max-w-none">{excerpt}</div>
            </div>
        )
    }
    <div class="max-w-3xl mx-auto mt-8">
        <a
            class="bg-primary hover:shadow-button inline-flex items-center justify-center gap-1.5 rounded-full px-8 py-2.5 font-semibold text-white transition duration-300"
            href={postHref}
        >
            {labels.continueReading}
        </a>
    </div>
</article>
