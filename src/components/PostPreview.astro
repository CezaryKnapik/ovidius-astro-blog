---
import { type CollectionEntry } from 'astro:content';
import { defaultLocale, type Locale } from '../i18n/config';
import { ui } from '../i18n/ui';
import { postUrl } from '../utils/i18n';
import CustomImage from './CustomImage.astro';
import FormattedDate from './FormattedDate.astro';
import PostTags from './PostTags.astro';

const { post, locale = defaultLocale } = Astro.props as { post: CollectionEntry<'blog'>; locale?: Locale };
const { title, publishDate, updatedDate, featureImage, excerpt, isFeatured, tags } = post.data;
const postHref = postUrl(locale, post);
const labels = ui[locale].common;
---

<article class="mb-12 post-card sm:mb-16">
    <header class="post-card-header">
        <div class="mb-2 text-sm tracking-wider uppercase text-slate-500">
            {
                isFeatured && (
                    <>
                        <span class="text-primary">{labels.featured}</span>
                        {' / '}
                    </>
                )
            }
            <FormattedDate date={publishDate} locale={locale} />
            {
                updatedDate && (
                    <>
                        {' '}
                        <span>
                            ({labels.updatedOn} <FormattedDate date={updatedDate} locale={locale} />)
                        </span>
                    </>
                )
            }
        </div>
        <h2 class="text-3xl font-bold text-slate-900"><a href={postHref}>{title}</a></h2>
        <PostTags tags={tags} class="mt-3" />
    </header>
    {
        featureImage?.src && (
            <figure class="mt-6 mb-6 post-card-thumbnail xl:mt-7 xl:mb-0">
                <a href={postHref}>
                    <CustomImage
                        {...featureImage}
                        class="w-full rounded-md"
                        widths={[160, 320, 480, 640, 768, 960, 1200]}
                        sizes="(min-width: 1280px) 160px, (min-width: 832px) 768px, calc(100vw - 32px)"
                    />
                </a>
            </figure>
        )
    }
    {
        excerpt && (
            <div class="mt-4 post-card-content">
                <div class="prose prose-slate sm:prose-lg max-w-none">{excerpt}</div>
            </div>
        )
    }
</article>

<style>
    @reference "tailwindcss";

    @media (min-width: 1280px) {
        .post-card-header {
            grid-area: header;
        }
        .post-card-content {
            grid-area: content;
        }
        .post-card-thumbnail {
            grid-area: thumbnail;
        }
        .post-card {
            @apply grid gap-x-8;
            grid-template-rows: min-content 1fr;
            grid-template-columns: 1fr 768px 1fr;
            grid-template-areas:
                'thumbnail header'
                'thumbnail content';
        }
    }
</style>
