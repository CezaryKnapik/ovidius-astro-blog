---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import CustomImage from '../../../components/CustomImage.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import PostTags from '../../../components/PostTags.astro';
import ReadNextPostPreview from '../../../components/ReadNextPostPreview.astro';
import { ui } from '../../../i18n/ui';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import type { AlternateLink } from '../../../types';
import { filterByLocale, getContentAlternateLinks, getContentSlug } from '../../../utils/i18n';
import { sortPostsByDateDesc } from '../../../utils/post-utils';

const locale = 'pl';

export async function getStaticPaths() {
    const allPosts = await getCollection('blog');
    const posts = filterByLocale(allPosts, 'pl').sort(sortPostsByDateDesc);
    const postCount = posts.length;
    return posts.map((post, index) => ({
        params: { id: getContentSlug(post) },
        props: {
            post,
            prevPost: index + 1 !== postCount ? posts[index + 1] : null,
            nextPost: index !== 0 ? posts[index - 1] : null,
            alternateLinks: getContentAlternateLinks(allPosts, post, 'blog')
        }
    }));
}

const {
    post,
    prevPost,
    nextPost,
    alternateLinks
} = Astro.props as { post: CollectionEntry<'blog'>; prevPost: CollectionEntry<'blog'> | null; nextPost: CollectionEntry<'blog'> | null; alternateLinks: AlternateLink[] };
const { title, publishDate, updatedDate, featureImage, excerpt, isFeatured, seo, tags } = post.data;
const { Content } = await render(post);
const labels = ui[locale].common;
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? excerpt} image={seo?.image ?? featureImage} pageType="article" locale={locale} alternateLinks={alternateLinks}>
    <main class="px-4 py-12 grow sm:px-8 sm:py-16">
        <article class="max-w-6xl mx-auto mb-12 sm:mb-16">
            <header class="max-w-3xl mx-auto mb-6 sm:mb-8">
                <div class="mb-3 text-sm tracking-wider uppercase text-slate-500">
                    {
                        isFeatured && (
                            <>
                                <span class="text-primary">{labels.featured}</span>
                                {' / '}
                            </>
                        )
                    }
                    <FormattedDate date={publishDate} locale={locale} />
                    {
                        updatedDate && (
                            <>
                                {' '}
                                <span>
                                    ({labels.updatedOn} <FormattedDate date={updatedDate} locale={locale} />)
                                </span>
                            </>
                        )
                    }
                </div>
                <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl md:text-5xl">{title}</h1>
                <PostTags tags={tags} class="mt-4" />
            </header>
            {
                featureImage?.src && (
                    <figure class="my-6 sm:my-8 lg:my-12">
                        <CustomImage
                            {...featureImage}
                            class="w-full rounded-lg"
                            widths={[480, 640, 768, 960, 1200, 1600]}
                            sizes="(min-width: 1216px) 1152px, calc(100vw - 32px)"
                        />
                        {featureImage.caption && <figcaption class="mt-1.5 text-xs sm:text-sm">{featureImage.caption}</figcaption>}
                    </figure>
                )
            }
            <div class="max-w-3xl mx-auto">
                <div class="prose prose-slate sm:prose-lg max-w-none">
                    <Content />
                </div>
            </div>
        </article>
        {
            (prevPost || nextPost) && (
                <div class="max-w-3xl mx-auto mb-12 sm:mb-16">
                    <h2 class="after:bg-primary mb-8 text-sm tracking-wider text-slate-900 uppercase after:mt-4 after:block after:h-px after:w-16 after:content-[''] sm:mb-12">
                        {labels.readNext}
                    </h2>
                    {nextPost && <ReadNextPostPreview post={nextPost} locale={locale} />}
                    {prevPost && <ReadNextPostPreview post={prevPost} locale={locale} />}
                </div>
            )
        }
    </main>
</BaseLayout>
