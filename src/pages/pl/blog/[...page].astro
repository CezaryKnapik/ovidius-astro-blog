---
import type { GetStaticPathsOptions, Page } from 'astro';
import { getCollection } from 'astro:content';
import Icon from '../../../components/Icon.astro';
import PostPreview from '../../../components/PostPreview.astro';
import { getSiteConfig } from '../../../data/site-config';
import { ui } from '../../../i18n/ui';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { filterByLocale, getRouteAlternateLinks } from '../../../utils/i18n';
import { sortPostsByDateDesc } from '../../../utils/post-utils';

const locale = 'pl';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const siteConfig = getSiteConfig('pl');
    const posts = filterByLocale(await getCollection('blog'), 'pl').sort(sortPostsByDateDesc);
    return paginate(posts, { pageSize: siteConfig.postsPerPage || 5 });
}

const { page } = Astro.props as { page: Page };
const labels = ui[locale];
const blog = page.data;
const currentPath = page.currentPage === 1 ? '/blog' : `/blog/${page.currentPage}`;
---

<BaseLayout title={labels.blog.title} description={labels.blog.description} locale={locale} alternateLinks={getRouteAlternateLinks(currentPath)}>
    <main class="grow px-4 py-12 sm:px-8 sm:py-16">
        <h1 class="sr-only">{labels.blog.title}</h1>
        <div class="mx-auto max-w-3xl xl:max-w-6xl">
            {blog.map((post) => <PostPreview post={post} locale={locale} />)}
        </div>
        <nav aria-label={labels.pagination.label} class="mx-auto my-12 max-w-3xl border-t border-slate-200 pt-12 sm:my-16 sm:pt-16">
            <div class="relative px-12 text-center">
                {
                    page.url.prev && (
                        <a
                            class="hover:bg-primary hover:shadow-button absolute top-1/2 left-0 inline-flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-slate-50 text-lg text-slate-700 transition duration-300 hover:text-white"
                            href={page.url.prev}
                            rel="prefetch"
                            aria-label={labels.pagination.goToPage(page.currentPage - 1, page.lastPage)}
                        >
                            <Icon icon="arrow-left" class="h-5 w-5 fill-current" />
                        </a>
                    )
                }
                <span class="text-sm tracking-wider text-slate-500 uppercase" aria-current="page">{labels.pagination.pageOf(page.currentPage, page.lastPage)}</span>
                {
                    page.url.next && (
                        <a
                            class="hover:bg-primary hover:shadow-button absolute top-1/2 right-0 inline-flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-slate-50 text-lg text-slate-700 transition duration-300 hover:text-white"
                            href={page.url.next}
                            rel="prefetch"
                            aria-label={labels.pagination.goToPage(page.currentPage + 1, page.lastPage)}
                        >
                            <Icon icon="arrow-right" class="h-5 w-5 fill-current" />
                        </a>
                    )
                }
            </div>
        </nav>
    </main>
</BaseLayout>
